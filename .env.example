# Data source mode: "demo" (default, bundled mockups) or "store" (real Supabase).
# Leave as demo for the current live site. See docs/DATA_SOURCES.md.
NEXT_PUBLIC_APP_MODE=demo

# Supabase (optional — the app runs with local mock data if these are empty)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
